# Execution mode: rules | llm | hybrid
MODE=hybrid

# LLM provider: groq | ollama
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Failure injection rate (0.0 - 1.0)
CHAOS=0.08

# Deterministic runs
SEED=42

# "Today" for deterministic policy decisions against the fixture dataset.
# The dataset is written for March 15-22, 2024, so this keeps return-window
# math aligned with the expected_action annotations.
TODAY=2024-03-15
